# ============================================================================
# Autonomous — Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your values before starting the platform.
#
#   cp .env.example .env
#
# For Docker Compose deployment, this file is read automatically.
# For local development, source it or set variables in your shell.
# ============================================================================

# ── Backend ─────────────────────────────────────────────────────────────────

# Secret key for JWT signing. MUST be changed in production.
# Generate one with:  python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE-ME-IN-PRODUCTION-use-openssl-rand-hex-32

# Database URL (default: SQLite for local dev)
# For PostgreSQL:  postgresql+asyncpg://user:password@host:5432/dbname
DATABASE_URL=sqlite+aiosqlite:///./data/autonomous_suite.db

# Authentication mode: "jwt" (default) or "oauth"
AUTH_MODE=jwt

# JWT token lifetimes
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── AI / LLM ───────────────────────────────────────────────────────────────

# Google Gemini API key (required for Agent Brain and Memory Palace)
# Get one at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ── GitHub Integration ──────────────────────────────────────────────────────

# GitHub Personal Access Token (optional, for DevOps agent features)
# Create one at: https://github.com/settings/tokens
GITHUB_TOKEN=

# ── OAuth (only if AUTH_MODE=oauth) ─────────────────────────────────────────

# OAUTH_DOMAIN=your-tenant.auth0.com
# OAUTH_CLIENT_ID=your-client-id
# OAUTH_CLIENT_SECRET=your-client-secret
# OAUTH_AUDIENCE=https://api.autonomous.local
# OAUTH_ISSUER=https://your-tenant.auth0.com/

# ── Frontend ────────────────────────────────────────────────────────────────

# Backend API URL (used at build time for React)
REACT_APP_API_URL=http://localhost:8000

# ── Docker / PostgreSQL (only for docker-compose) ──────────────────────────

POSTGRES_USER=autonomous_user
POSTGRES_PASSWORD=autonomous_password
POSTGRES_DB=autonomous_db
